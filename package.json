{
  "name": "astro-theme-anglefeint",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "keywords": [
    "astro",
    "astro-theme",
    "blog",
    "portfolio",
    "cyberpunk"
  ],
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "astro dev",
    "build": "astro build",
    "check:docs": "node scripts/validate-doc-metadata.mjs",
    "check:fonts": "node scripts/check-font-assets.mjs",
    "check:workspace-link": "node scripts/check-workspace-link.mjs",
    "maintainer:sync-starter": "node tools/maintainer/sync-starter.mjs",
    "maintainer:sync-starter:check": "node tools/maintainer/sync-starter.mjs --check",
    "release:starter": "node tools/maintainer/sync-starter.mjs --from=main",
    "release:starter:push": "node tools/maintainer/sync-starter.mjs --from=main --push",
    "check:adapters": "node scripts/check-adapter-contract.mjs && node scripts/sync-adapters.mjs --check",
    "check:about-runtime": "npm run build && node scripts/check-about-runtime-config.mjs",
    "check:no-build": "npm run check:docs && npm run check:workspace-link && npm run check:fonts && npm run check:adapters && npm run check:pack-cli && npm run test && npm run check:scaffold && astro check",
    "check:pack-cli": "node scripts/check-theme-pack-cli.mjs",
    "check:scaffold": "node scripts/check-scaffold.mjs",
    "sync-adapters": "node scripts/sync-adapters.mjs",
    "doctor": "npm run check:adapters && npm run check",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.mjs\"",
    "check": "npm run check:no-build && npm run check:about-runtime",
    "lint": "eslint \"{scripts,packages,src,tests}/**/*.{js,mjs}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"**/*.{js,mjs,ts,astro,md,json,jsonc,css}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,astro,md,json,jsonc,css}\"",
    "preview": "astro preview",
    "e2e:install": "playwright install chromium",
    "e2e:prepare": "node scripts/build-e2e-smoke-config.mjs",
    "e2e": "npm run build && npm run e2e:prepare && playwright test",
    "release:npm": "node scripts/release-npm.mjs",
    "new-post": "node ./node_modules/@anglefeint/astro-theme/src/cli-new-post.mjs",
    "new-page": "node ./node_modules/@anglefeint/astro-theme/src/cli-new-page.mjs",
    "astro": "astro",
    "theme:pack": "npm pack --workspace @anglefeint/astro-theme"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,astro,md,json,jsonc,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anglefeint/astro-theme": "workspace:*",
    "@astrojs/mdx": "^5.0.0-beta.9",
    "@astrojs/rss": "^4.0.15-beta.4",
    "@astrojs/sitemap": "^3.6.1-beta.3",
    "astro": "^6.0.0-beta.17",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7-beta.1",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.65.0"
  }
}
