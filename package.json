{
  "name": "astro-theme-anglefeint",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "keywords": [
    "astro",
    "astro-theme",
    "blog",
    "portfolio",
    "cyberpunk"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check:adapters": "node scripts/check-adapter-contract.mjs && node scripts/sync-adapters.mjs --check",
    "check:about-runtime": "npm run build && node scripts/check-about-runtime-config.mjs",
    "sync-adapters": "node scripts/sync-adapters.mjs",
    "doctor": "npm run check:adapters && npm run check",
    "check": "npm run check:adapters && astro check && npm run check:about-runtime",
    "preview": "astro preview",
    "new-post": "node ./node_modules/@anglefeint/astro-theme/src/cli-new-post.mjs",
    "new-page": "node ./node_modules/@anglefeint/astro-theme/src/cli-new-page.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@anglefeint/astro-theme": "^0.1.28",
    "@astrojs/mdx": "5.0.0-beta.9",
    "@astrojs/rss": "4.0.15-beta.4",
    "@astrojs/sitemap": "3.6.1-beta.3",
    "astro": "6.0.0-beta.17",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.7-beta.1",
    "typescript": "^5.9.3"
  }
}
