---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import HomePage from '@anglefeint/astro-theme/layouts/HomePage.astro';
import { SITE_URL } from '../../config/site';
import { THEME } from '../../config/theme';
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  type Locale,
  getDefaultLocaleHomePath,
  isLocale,
  shouldRedirectLocalizedDefaultLocaleHome,
} from '../../i18n/config';
import { postsForLocale } from '../../i18n/posts';

export const getStaticPaths = (async () =>
  SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
  }))) satisfies GetStaticPaths;

const langParam = Astro.params.lang ?? DEFAULT_LOCALE;
const locale: Locale = isLocale(langParam) ? langParam : DEFAULT_LOCALE;
const shouldRedirect = shouldRedirectLocalizedDefaultLocaleHome(locale);
const latestPosts = shouldRedirect
  ? []
  : postsForLocale(await getCollection('blog'), locale).slice(0, THEME.HOME_LATEST_COUNT);
const siteURL = Astro.site ?? SITE_URL;
const redirectHref = getDefaultLocaleHomePath();
---

{
  shouldRedirect ? (
    <html lang={DEFAULT_LOCALE}>
      <head>
        <meta charset="utf-8" />
        <meta name="robots" content="noindex, follow" />
        <meta http-equiv="refresh" content={`0;url=${redirectHref}`} />
        <link rel="canonical" href={new URL(redirectHref, siteURL)} />
        <title>Redirecting...</title>
      </head>
      <body>
        <p>
          Redirecting to <a href={redirectHref}>home</a>…
        </p>
      </body>
    </html>
  ) : (
    <HomePage locale={locale} latestPosts={latestPosts} />
  )
}
