---
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '@anglefeint/astro-theme/components/FormattedDate.astro';
import CyberShell from '@anglefeint/astro-theme/layouts/shells/CyberShell.astro';
import { SITE_TITLE } from '../../../consts';
import { THEME } from '../../../config/theme';
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  type Locale,
  blogIdToSlugAnyLocale,
  isLocale,
  localePath,
} from '../../../i18n/config';
import { getMessages } from '../../../i18n/messages';
import { BLOG_PAGE_SIZE, postsForLocale } from '../../../i18n/posts';
import { buildPaginationModel } from '../../../utils/pagination';
import {
  resolvePaginationItemVariant,
  resolvePaginationVariant,
} from '../../../utils/pagination-style';

export const getStaticPaths = (async () => {
  const all = await getCollection('blog');
  return SUPPORTED_LOCALES.flatMap((locale) => {
    const localizedPosts = postsForLocale(all, locale);
    const totalPages = Math.max(1, Math.ceil(localizedPosts.length / BLOG_PAGE_SIZE));

    return Array.from({ length: totalPages }, (_, pageIndex) => {
      const currentPage = pageIndex + 1;
      const start = pageIndex * BLOG_PAGE_SIZE;
      const data = localizedPosts.slice(start, start + BLOG_PAGE_SIZE);
      const prev =
        currentPage > 1
          ? currentPage === 2
            ? localePath(locale, '/blog/')
            : localePath(locale, `/blog/${currentPage - 1}`)
          : undefined;
      const next =
        currentPage < totalPages ? localePath(locale, `/blog/${currentPage + 1}`) : undefined;

      return {
        params: currentPage === 1 ? { lang: locale } : { lang: locale, page: String(currentPage) },
        props: {
          locale,
          page: {
            data,
            currentPage,
            lastPage: totalPages,
            url: { prev, next },
          },
        },
      };
    });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = (Astro.props.locale ?? Astro.params.lang ?? DEFAULT_LOCALE) as Locale;
const resolvedLocale: Locale = isLocale(locale) ? locale : DEFAULT_LOCALE;
const messages = getMessages(resolvedLocale);
const posts = page.data;
const paginationModel = buildPaginationModel({
  currentPage: page.currentPage,
  totalPages: page.lastPage,
  windowSize: THEME.PAGINATION.WINDOW_SIZE,
  showJumpThreshold: THEME.PAGINATION.SHOW_JUMP_THRESHOLD,
});
const paginationVariant = resolvePaginationVariant({
  currentPage: paginationModel.currentPage,
  totalPages: paginationModel.totalPages,
  locale: resolvedLocale,
  pathname: Astro.url.pathname,
  config: THEME.PAGINATION.STYLE,
});
const blogRoot = localePath(resolvedLocale, '/blog/');
const pageHref = (pageNum: number) =>
  pageNum === 1 ? blogRoot : localePath(resolvedLocale, `/blog/${pageNum}`);
const isRandomItemStyle =
  THEME.PAGINATION.STYLE.MODE === 'random' && THEME.PAGINATION.STYLE.ENABLED;
const itemVariantClass = (seed: string, index: number) =>
  isRandomItemStyle
    ? 'pg-var-random'
    : resolvePaginationItemVariant({
        seed,
        index,
        config: THEME.PAGINATION.STYLE,
      }).className;
const jumpToText = messages.blog.jumpTo || 'Jump to page';
const jumpInputLabelText = messages.blog.jumpInputLabel || 'Page number';
const prevClass = itemVariantClass(`${resolvedLocale}:prev:${paginationModel.currentPage}`, 0);
const nextClass = itemVariantClass(
  `${resolvedLocale}:next:${paginationModel.currentPage}`,
  paginationModel.items.length + 2
);
const allPosts = await getCollection('blog');
const localeHrefs = Object.fromEntries(
  SUPPORTED_LOCALES.map((targetLocale) => {
    const totalPages = Math.max(
      1,
      Math.ceil(postsForLocale(allPosts, targetLocale).length / BLOG_PAGE_SIZE)
    );
    const href =
      page.currentPage <= totalPages
        ? page.currentPage === 1
          ? localePath(targetLocale, '/blog/')
          : localePath(targetLocale, `/blog/${page.currentPage}`)
        : localePath(targetLocale, '/blog/');
    return [targetLocale, href];
  })
) as Partial<Record<Locale, string>>;
const pageTitle =
  page.currentPage === 1
    ? `${messages.blog.title} | ${SITE_TITLE}`
    : `${messages.blog.pageTitle} ${page.currentPage} | ${SITE_TITLE}`;
const pageDescription =
  page.currentPage === 1
    ? messages.blog.archiveDescription
    : `${messages.blog.pageDescription} ${page.currentPage}.`;

// Blade Runner: 负 delay 让雨滴首次加载即分布全屏
const rainTypes = ['normal', 'thin', 'fog', 'skew'];
const rainDrops = Array.from({ length: 48 }, (_, i) => {
  const type = rainTypes[i % 4];
  return {
    left: `${Math.random() * 100}%`,
    delay: `${-5 + Math.random() * 6}s`,
    duration: `${3.3 + Math.random() * (type === 'thin' ? 1.1 : type === 'fog' || type === 'skew' ? 1.7 : 1.4)}s`,
    opacity: type === 'fog' ? 0.12 + Math.random() * 0.1 : 0.2 + Math.random() * 0.25,
    type,
  };
});
const dustParticles = Array.from({ length: 22 }, () => ({
  left: `${Math.random() * 100}%`,
  top: `${Math.random() * 100}%`,
  size: 4 + Math.random() * 4,
  delay: `${Math.random() * 10}s`,
  duration: `${8 + Math.random() * 12}s`,
}));
---

<CyberShell
  locale={resolvedLocale}
  title={pageTitle}
  description={pageDescription}
  localeHrefs={localeHrefs}
>
  <Fragment slot="body-start">
    <h1 class="sr-only">{pageTitle}</h1>
    <div class="cyber-rain" aria-hidden="true">
      {
        rainDrops.map((drop) => (
          <div
            class={`cyber-rain-drop cyber-rain-drop--${drop.type}`}
            style={{
              left: drop.left,
              animationDelay: drop.delay,
              animationDuration: drop.duration,
              opacity: drop.opacity,
            }}
          />
        ))
      }
    </div>
    <div class="cyber-dust" aria-hidden="true">
      {
        dustParticles.map((p) => (
          <div
            class="cyber-dust-particle"
            style={{
              left: p.left,
              top: p.top,
              width: p.size,
              height: p.size,
              animationDelay: p.delay,
              animationDuration: p.duration,
            }}
          />
        ))
      }
    </div>
  </Fragment>
  <section>
    <h2 class="sr-only">{messages.blog.title}</h2>
    <ul>
      {
        posts.map((post, index) => (
          <li>
            <a href={localePath(resolvedLocale, `/blog/${blogIdToSlugAnyLocale(post.id)}`)}>
              {post.data.heroImage && (
                <div class="img-wrapper">
                  <Image
                    width={index === 0 ? 1200 : 720}
                    height={index === 0 ? 600 : 360}
                    sizes={
                      index === 0
                        ? '(max-width: 720px) 100vw, 960px'
                        : '(max-width: 720px) 100vw, 480px'
                    }
                    src={post.data.heroImage}
                    alt={post.data.title}
                  />
                </div>
              )}
              <h2 class="title">{post.data.title}</h2>
              <p class="date">
                <FormattedDate date={post.data.pubDate} locale={resolvedLocale} />
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
  {
    page.lastPage > 1 && (
      <div class={`pagination-wrap ${paginationVariant.className}`}>
        <div
          class="pagination-style-config sr-only"
          data-style-mode={THEME.PAGINATION.STYLE.MODE}
          data-style-variants={THEME.PAGINATION.STYLE.VARIANTS}
        />
        <nav class="pagination" aria-label="Pagination">
          {page.url.prev && (
            <a
              class={`pg-item pg-nav ${prevClass}`}
              href={page.url.prev}
              aria-label={messages.blog.previous}
            >
              {messages.blog.previous}
            </a>
          )}
          {paginationModel.items.map((item, index) =>
            item.kind === 'ellipsis' ? (
              <span
                class={`pg-item pg-ellipsis ${itemVariantClass(
                  `${resolvedLocale}:ellipsis:${item.id}`,
                  index
                )}`}
                aria-hidden="true"
              >
                ...
              </span>
            ) : (
              <a
                class={`pg-item ${itemVariantClass(
                  `${resolvedLocale}:page:${item.page}`,
                  index
                )} ${item.page === paginationModel.currentPage ? 'current' : ''}`}
                href={pageHref(item.page)}
                aria-current={item.page === paginationModel.currentPage ? 'page' : undefined}
              >
                {item.page}
              </a>
            )
          )}
          {page.url.next && (
            <a
              class={`pg-item pg-nav ${nextClass}`}
              href={page.url.next}
              aria-label={messages.blog.next}
            >
              {messages.blog.next}
            </a>
          )}
        </nav>
        {THEME.PAGINATION.JUMP.ENABLED && paginationModel.showJump && (
          <form
            class="pagination-jump"
            data-blog-root={blogRoot}
            data-total-pages={paginationModel.totalPages}
            data-enter-to-go={THEME.PAGINATION.JUMP.ENTER_TO_GO ? 'true' : 'false'}
            aria-label={jumpToText}
          >
            <label class="sr-only" for="pagination-jump-input">
              {jumpInputLabelText}
            </label>
            <span class="pagination-jump-label">{jumpToText}</span>
            <input
              id="pagination-jump-input"
              class="pagination-jump-input"
              type="text"
              inputmode="numeric"
              pattern="[0-9]*"
              value={paginationModel.currentPage}
            />
            <button type="submit" class="pagination-jump-btn">
              {messages.blog.jumpGo || 'Go'}
            </button>
          </form>
        )}
      </div>
    )
  }
</CyberShell>

<script is:inline>
  document.querySelectorAll('.pagination-wrap').forEach((wrap) => {
    const configEl = wrap.querySelector('.pagination-style-config');
    if (!(configEl instanceof HTMLElement)) return;
    if (configEl.dataset.styleMode !== 'random') return;
    const variants = Math.max(
      1,
      Math.min(12, Number.parseInt(configEl.dataset.styleVariants || '9', 10))
    );
    const items = wrap.querySelectorAll('.pagination .pg-item');
    items.forEach((item) => {
      item.className = item.className.replace(/\bpg-var-\d+\b/g, '').trim();
      const variant = Math.floor(Math.random() * variants) + 1;
      item.classList.add(`pg-var-${variant}`);
    });
  });

  document.querySelectorAll('.pagination-jump').forEach((form) => {
    const blogRoot = form.getAttribute('data-blog-root') || '/blog/';
    const totalPages = Math.max(1, parseInt(form.getAttribute('data-total-pages') || '1', 10));
    const enterToGo = form.getAttribute('data-enter-to-go') !== 'false';
    const input = form.querySelector('.pagination-jump-input');
    if (!(input instanceof HTMLInputElement)) return;

    const normalizeRoot = (root) => {
      if (!root) return '/blog/';
      return root.endsWith('/') ? root : `${root}/`;
    };

    const toHref = (pageNum) => {
      const root = normalizeRoot(blogRoot);
      return pageNum === 1 ? root : `${root}${pageNum}/`;
    };

    const runJump = () => {
      const normalized = (input.value || '').replace(/[^\d]/g, '');
      const value = Number.parseInt(normalized || '1', 10);
      if (!Number.isFinite(value)) return;
      const target = Math.max(1, Math.min(totalPages, Math.round(value)));
      window.location.assign(toHref(target));
    };

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      runJump();
    });

    if (!enterToGo) {
      input.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter') return;
        event.preventDefault();
      });
    }
  });
</script>
