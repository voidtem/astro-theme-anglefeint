---
import type { GetStaticPaths } from 'astro';
import BasePageLayout from '@anglefeint/astro-theme/layouts/BasePageLayout.astro';
import { ENABLED_LOCALES, type Locale } from '@anglefeint/site-i18n/config';

export const getStaticPaths = (() =>
  ENABLED_LOCALES.map((lang: Locale) => ({ params: { lang } }))) satisfies GetStaticPaths;

const locale = Astro.params.lang as Locale;
const pageTitle = 'Projects';
const pageDescription = 'A custom page built from the default layout.';
---

<BasePageLayout locale={locale} title={pageTitle} description={pageDescription}>
  <h1>Projects</h1>
  <p>Replace this content with your own page content.</p>
</BasePageLayout>
