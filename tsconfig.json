{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "scripts/adapter-templates"],
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@anglefeint/site-config": ["src/config/index.ts"],
      "@anglefeint/site-config/*": ["src/config/*"],
      "@anglefeint/site-i18n": ["src/i18n/config.ts"],
      "@anglefeint/site-i18n/*": ["src/i18n/*"],
      "@anglefeint/astro-theme/components/*": [
        "packages/theme/src/components/*",
        "node_modules/@anglefeint/astro-theme/src/components/*"
      ],
      "@anglefeint/theme-default-i18n": [
        "packages/theme/src/i18n/messages.ts",
        "node_modules/@anglefeint/astro-theme/src/i18n/messages.ts"
      ],
      "@anglefeint/astro-theme/utils/*": [
        "packages/theme/src/utils/*",
        "node_modules/@anglefeint/astro-theme/src/utils/*"
      ]
    }
  }
}
